<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="nicolasmneves.sistemacadastroclientes.ClientesController">
   <top>
      <VBox spacing="10.0">
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label text="Cadastro de Clientes">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>

            <GridPane hgap="10.0" vgap="8.0">
               <columnConstraints>
                  <ColumnConstraints minWidth="70.0" />
                  <ColumnConstraints minWidth="180.0" />
                  <ColumnConstraints minWidth="70.0" />
                  <ColumnConstraints minWidth="180.0" />
                  <ColumnConstraints minWidth="70.0" />
                  <ColumnConstraints minWidth="180.0" />
               </columnConstraints>
               <children>
                  <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="idField" prefWidth="80.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label text="Nome:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <TextField fx:id="nomeField" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                  <CheckBox fx:id="ativoCheck" selected="true" text="Ativo" GridPane.columnIndex="4" GridPane.rowIndex="0" GridPane.columnSpan="2" />

                  <Label text="CPF:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="cpfField" promptText="000.000.000-00" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label text="E-mail:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <TextField fx:id="emailField" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                  <Label text="Telefone:" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                  <TextField fx:id="telefoneField" GridPane.columnIndex="5" GridPane.rowIndex="1" />

                  <Label text="Cidade:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="cidadeField" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="2" />
               </children>
            </GridPane>

            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="pesquisaField" prefWidth="250.0" promptText="Pesquisar por nome" />
                  <Button fx:id="pesquisarButton" mnemonicParsing="false" onAction="#handlePesquisar" text="Pesquisar" />
                  <Button fx:id="mostrarTodosButton" mnemonicParsing="false" onAction="#handleMostrarTodos" text="Mostrar Todos" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <center>
      <TableView fx:id="tabelaClientes" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colNome" prefWidth="160.0" text="Nome" />
            <TableColumn fx:id="colCpf" prefWidth="110.0" text="CPF" />
            <TableColumn fx:id="colEmail" prefWidth="150.0" text="E-mail" />
            <TableColumn fx:id="colTelefone" prefWidth="120.0" text="Telefone" />
            <TableColumn fx:id="colCidade" prefWidth="110.0" text="Cidade" />
            <TableColumn fx:id="colSituacao" prefWidth="80.0" text="Situação" />
            <TableColumn fx:id="colDataCadastro" prefWidth="140.0" text="Data de Cadastro" />
         </columns>
         <BorderPane.margin>
            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
         </BorderPane.margin>
      </TableView>
   </center>

   <bottom>
      <HBox alignment="CENTER" spacing="10.0">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="5.0" />
         </padding>
         <children>
            <Button fx:id="novoButton" mnemonicParsing="false" onAction="#handleNovo" prefWidth="90.0" text="Novo" />
            <Button fx:id="salvarButton" mnemonicParsing="false" onAction="#handleSalvar" prefWidth="90.0" text="Salvar" />
            <Button fx:id="editarButton" mnemonicParsing="false" onAction="#handleEditar" prefWidth="90.0" text="Editar" />
            <Button fx:id="ativarDesativarButton" mnemonicParsing="false" onAction="#handleAtivarDesativar" prefWidth="140.0" text="Ativar/Desativar" />
            <Button fx:id="excluirButton" mnemonicParsing="false" onAction="#handleExcluir" prefWidth="90.0" text="Excluir" />
            <Button fx:id="cancelarButton" mnemonicParsing="false" onAction="#handleCancelar" prefWidth="90.0" text="Cancelar" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
